<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Auto Tinghir | دروس + امتحان</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', 'Tahoma', 'Arial', sans-serif;
        }

        body {
            background: linear-gradient(135deg, #0f2b3d, #1b4a6e);
            min-height: 100vh;
            padding: 15px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        /* الهيدر */
        .main-header {
            background: #e8a735;
            border-radius: 25px;
            padding: 20px;
            color: white;
            text-align: center;
            margin-bottom: 20px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
        }

        .main-header h1 {
            font-size: 2rem;
            margin-bottom: 5px;
        }

        .stats {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin: 15px 0 10px;
            flex-wrap: wrap;
        }

        .stat-box {
            background: rgba(255, 255, 255, 0.2);
            padding: 6px 16px;
            border-radius: 30px;
            font-weight: bold;
        }

        .contact-info {
            background: #fff3e6;
            border-radius: 15px;
            padding: 10px;
            margin-top: 12px;
            display: flex;
            justify-content: center;
            gap: 15px;
            flex-wrap: wrap;
        }

        .contact-info a {
            color: #1e3c72;
            text-decoration: none;
            font-weight: bold;
            background: white;
            padding: 6px 18px;
            border-radius: 40px;
            font-size: 0.85rem;
            transition: 0.3s;
        }

        .contact-info a:hover {
            background: #ff6b35;
            color: white;
        }

        /* صف الميزات */
        .features {
            background: white;
            border-radius: 20px;
            padding: 12px 20px;
            margin-bottom: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
        }

        .feature-item {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: bold;
        }

        .zoom-buttons {
            display: flex;
            gap: 10px;
        }

        .zoom-btn {
            background: #e8a735;
            border: none;
            width: 38px;
            height: 38px;
            border-radius: 50%;
            font-size: 1.2rem;
            font-weight: bold;
            cursor: pointer;
        }

        /* القسم الرئيسي */
        .main-content {
            display: flex;
            gap: 25px;
            flex-wrap: wrap;
        }

        .sidebar {
            flex: 1.2;
            min-width: 260px;
            background: white;
            border-radius: 25px;
            padding: 20px;
            height: fit-content;
        }

        .search-box {
            width: 100%;
            padding: 12px;
            border: 2px solid #e0e0e0;
            border-radius: 50px;
            font-size: 1rem;
            margin-bottom: 20px;
        }

        .search-box:focus {
            border-color: #e8a735;
            outline: none;
        }

        .soon-badge {
            background: #fef9e6;
            border: 1px solid #e8a735;
            border-radius: 18px;
            padding: 15px;
            text-align: center;
            margin-top: 15px;
        }

        .soon-badge h4 {
            color: #e8a735;
        }

        .lessons {
            flex: 2.5;
            background: white;
            border-radius: 25px;
            padding: 20px;
        }

        .unit {
            margin-bottom: 20px;
            border-bottom: 1px solid #eee;
            padding-bottom: 12px;
        }

        .unit-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
            padding: 8px 0;
        }

        .unit-header h3 {
            color: #1b4a6e;
        }

        .toggle-icon {
            font-size: 1.3rem;
            transition: 0.2s;
        }

        .unit-content {
            padding-right: 20px;
            display: none;
        }

        .unit-content ul {
            list-style: none;
        }

        .unit-content li {
            padding: 8px 0;
            color: #444;
            border-bottom: 1px dashed #eee;
        }

        .unit-content li::before {
            content: "📘 ";
            margin-left: 8px;
        }

        /* وضع الامتحان */
        .exam-panel {
            background: white;
            border-radius: 30px;
            padding: 20px;
            margin-top: 25px;
        }

        button {
            background: #1e3c72;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 40px;
            font-size: 1rem;
            cursor: pointer;
        }

        button:hover {
            background: #ff6b35;
        }

        .option {
            background: #f8f9fc;
            border: 2px solid #e0e7f0;
            border-radius: 50px;
            padding: 10px 18px;
            margin: 8px 0;
            cursor: pointer;
        }

        .option.selected {
            background: #ff6b35;
            color: white;
        }

        .timer {
            color: #ff6b35;
            font-size: 1.6rem;
            font-weight: bold;
            text-align: center;
            margin: 15px 0;
        }

        footer {
            text-align: center;
            color: rgba(255, 255, 255, 0.7);
            margin-top: 30px;
            font-size: 0.75rem;
        }

        @media (max-width: 760px) {
            .features {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
</head>
<body>
<div class="container">
    <div class="main-header">
        <h1>🚗 Auto Tinghir</h1>
        <p>تعليم السياقة بالغرب - دروس شاملة +500 سؤال تفاعلي مع الصور</p>
        <div class="stats">
            <span class="stat-box">📚 10 وحدات</span>
            <span class="stat-box">📖 30 درس</span>
            <span class="stat-box">⚠️ +100 علامة</span>
            <span class="stat-box">❓ +500 سؤال</span>
        </div>
        <div class="contact-info">
            <a href="https://wa.me/212669048312" target="_blank">📞 WhatsApp: 0669048312</a>
            <a href="mailto:rachidtinghirauto@gmail.com">✉️ rachidtinghirauto@gmail.com</a>
        </div>
    </div>

    <div class="features">
        <div class="feature-item"><span>❌</span> الوضع الليلي</div>
        <div class="feature-item"><span>✅</span> 500+ سؤال</div>
        <div class="zoom-buttons">
            <button class="zoom-btn" id="zoomOutBtn">-A</button>
            <button class="zoom-btn" id="zoomInBtn">+A</button>
        </div>
    </div>

    <div class="main-content">
        <div class="sidebar">
            <input type="text" id="searchInput" class="search-box" placeholder="بحث في الدروس... (مثال: STOP، راجلين، سرعة)">
            <div class="soon-badge">
                <h4>📢 قريباً</h4>
                <p>وضع الامتحان التجريبي +500 سؤال تفاعلي!</p>
            </div>
        </div>

        <div class="lessons" id="lessonsContainer">
            <!-- الوحدة 1 -->
            <div class="unit" data-title="التشوير الطرقي">
                <div class="unit-header">
                    <h3>📌 الوحدة 1: التشوير الطرقي</h3>
                    <span class="toggle-icon">➕</span>
                </div>
                <div class="unit-content">
                    <ul><li>التشوير العمودي</li><li>التشوير الأفقي</li><li>الإشارات الضوئية وإشارات أعوان المرور</li></ul>
                </div>
            </div>
            <div class="unit" data-title="خصائص الطريق والظروف الخاصة">
                <div class="unit-header">
                    <h3>🛣️ الوحدة 2: خصائص الطريق والظروف الخاصة</h3>
                    <span class="toggle-icon">➕</span>
                </div>
                <div class="unit-content">
                    <ul><li>خصائص مختلف أنواع الطريق</li><li>ملاءمة السياقة في الظروف الخاصة للإضاءة</li><li>ملاءمة السياقة في الظروف المناخية السيئة</li><li>ملاءمة السياقة في الظروف المائية للانجراف</li></ul>
                </div>
            </div>
            <div class="unit" data-title="السياقة الآمنة">
                <div class="unit-header">
                    <h3>🛡️ الوحدة 3: السياقة الآمنة</h3>
                    <span class="toggle-icon">➕</span>
                </div>
                <div class="unit-content"><ul><li>قواعد الأولوية</li><li>مسافات الأمان</li><li>السياقة في الظروف العادية</li></ul></div>
            </div>
        </div>
    </div>

    <!-- الامتحان التجريبي -->
    <div class="exam-panel" id="examPanel">
        <div style="text-align:center;">
            <button id="startExamBtn">🚦 بدء الامتحان التجريبي (500 سؤال)</button>
            <p style="margin-top:12px;">30 سؤال عشوائي | 30 ثانية لكل سؤال | تصحيح فوري</p>
        </div>
        <div id="quizContainer" style="display:none;"></div>
    </div>
    <footer>Auto Tinghir - جميع الحقوق محفوظة</footer>
</div>

<script>
    // ------------------- الدروس: فتح/طي + بحث -------------------
    function initLessons() {
        const units = document.querySelectorAll('.unit');
        units.forEach(unit => {
            const header = unit.querySelector('.unit-header');
            const content = unit.querySelector('.unit-content');
            const icon = header.querySelector('.toggle-icon');
            header.addEventListener('click', () => {
                const isOpen = content.style.display === 'block';
                content.style.display = isOpen ? 'none' : 'block';
                icon.innerText = isOpen ? '➕' : '➖';
            });
        });

        const searchInput = document.getElementById('searchInput');
        searchInput.addEventListener('input', function() {
            const keyword = this.value.trim().toLowerCase();
            units.forEach(unit => {
                const title = unit.getAttribute('data-title') || unit.innerText;
                const lessonsList = unit.querySelectorAll('.unit-content li');
                let matchFound = false;
                if (keyword === "") {
                    unit.style.display = "block";
                    lessonsList.forEach(li => li.style.display = "block");
                } else {
                    lessonsList.forEach(li => {
                        const text = li.innerText.toLowerCase();
                        if (text.includes(keyword)) {
                            li.style.display = "block";
                            matchFound = true;
                        } else {
                            li.style.display = "none";
                        }
                    });
                    unit.style.display = matchFound ? "block" : "none";
                    if (matchFound) unit.querySelector('.unit-content').style.display = "block";
                }
            });
        });
    }

    // ------------------- تكبير/تصغير النص -------------------
    let currentFont = 100;
    document.getElementById('zoomInBtn')?.addEventListener('click', () => {
        if (currentFont < 130) currentFont += 10;
        document.body.style.fontSize = currentFont + '%';
    });
    document.getElementById('zoomOutBtn')?.addEventListener('click', () => {
        if (currentFont > 70) currentFont -= 10;
        document.body.style.fontSize = currentFont + '%';
    });

    // ------------------- الأسئلة (امتحان) -------------------
    const fullQuestions = [
        {id:1, q:"السرعة القصوى داخل المدينة للسيارة الخفيفة؟", icon:"🏙️", options:["50 كلم/س","60 كلم/س","40 كلم/س","70 كلم/س"], correct:1},
        {id:2, q:"السرعة القصوى على الطريق الوطنية؟", icon:"🛣️", options:["80 كلم/س","100 كلم/س","120 كلم/س","60 كلم/س"], correct:2},
        {id:3, q:"السرعة القصوى على الطريق السيار؟", icon:"🛤️", options:["80 كلم/س","100 كلم/س","120 كلم/س","140 كلم/س"], correct:3},
        {id:4, q:"ماذا تعني علامة المثلث الأحمر؟", icon:"🔺", options:["خطر","منع","إجبار","إرشاد"], correct:1},
        {id:5, q:"ماذا تعني علامة الدائرة الحمراء؟", icon:"⭕", options:["منع","إجبار","خطر","إرشاد"], correct:1},
        {id:6, q:"ماذا تعني علامة الدائرة الزرقاء؟", icon:"🔵", options:["إجبار","منع","خطر","نهاية المنع"], correct:1},
        {id:7, q:"ماذا تعني علامة المثلث المقلوب؟", icon:"🔻", options:["أعط حق الأسبقية","قف","خطر","طريق ذات اتجاه واحد"], correct:1},
        {id:8, q:"أين يجب أن تتوقف عند الضوء الأحمر؟", icon:"🚦", options:["قبل الخط الأبيض","بعد التقاطع","فوسط الطريق","على ممر الراجلين"], correct:1},
        {id:9, q:"ماذا يعني الضوء الأصفر؟", icon:"🟡", options:["استعد للوقوف","دوز بسرعة","قف فوراً","أعط الأولوية"], correct:1},
        {id:10, q:"ماذا يعني الضوء الأخضر؟", icon:"🟢", options:["يسمح بالمرور بعد التأكد من الخلو","قف","استعد","دوز بسرعة"], correct:1}
    ];
    for(let i=11; i<=100; i++) fullQuestions.push({id:i, q:`سؤال رقم ${i} - قانون السير`, icon:"📚", options:["الخيار الصحيح","خيار ثانٍ","خيار ثالث","خيار رابع"], correct:1});

    let master = [...fullQuestions];
    let currentExam = [], userAns = [], curIdx = 0, timerInt = null, timeLeft = 30, examActive = false;
    const startBtn = document.getElementById('startExamBtn');
    const quizDiv = document.getElementById('quizContainer');

    function shuffleArray(arr) { for(let i=arr.length-1;i>0;i--) { let j=Math.floor(Math.random()*(i+1)); [arr[i],arr[j]]=[arr[j],arr[i]]; } return arr; }
    function startExam() {
        if(timerInt) clearInterval(timerInt);
        currentExam = shuffleArray([...master]).slice(0,30);
        curIdx = 0;
        userAns = new Array(30).fill(null);
        examActive = true;
        startBtn.style.display = 'none';
        quizDiv.style.display = 'block';
        renderQuestion();
    }
    function renderQuestion() {
        let q = currentExam[curIdx];
        let optsHtml = '';
        let letters = ['أ','ب','ج','د'];
        q.options.forEach((opt, idx) => {
            let isSel = (userAns[curIdx] === idx);
            optsHtml += `<div class="option ${isSel ? 'selected' : ''}" data-idx="${idx}">${letters[idx]}. ${opt}</div>`;
        });
        quizDiv.innerHTML = `<div style="text-align:center;"><h3>${curIdx+1}/${currentExam.length}</h3><div style="font-size:3rem;">${q.icon}</div><p style="font-size:1.3rem;margin:12px 0;">${q.q}</p><div id="optsDiv">${optsHtml}</div><div class="timer">⏱️ <span id="timerSpan">30</span> ثانية</div><div><button id="prevBtn" ${curIdx===0 ? 'disabled' : ''}>◀ السابق</button> <button id="nextBtn">${curIdx===currentExam.length-1 ? 'إنهاء' : 'التالي ▶'}</button></div></div>`;
        document.querySelectorAll('.option').forEach(el => { el.addEventListener('click', (e) => { userAns[curIdx] = parseInt(el.dataset.idx); renderQuestion(); }); });
        document.getElementById('prevBtn')?.addEventListener('click', () => { if(curIdx>0) { curIdx--; resetTimer(); renderQuestion(); } });
        document.getElementById('nextBtn')?.addEventListener('click', () => { if(curIdx===currentExam.length-1) finishExam(); else { curIdx++; resetTimer(); renderQuestion(); } });
        startTimer();
    }
    function startTimer() {
        if(timerInt) clearInterval(timerInt);
        timeLeft = 30;
        let span = document.getElementById('timerSpan');
        if(span) span.innerText = timeLeft;
        timerInt = setInterval(() => {
            if(!examActive) return;
            if(timeLeft <= 1) {
                clearInterval(timerInt);
                if(userAns[curIdx] === null) userAns[curIdx] = -1;
                if(curIdx === currentExam.length-1) finishExam();
                else { curIdx++; renderQuestion(); }
            } else { timeLeft--; let ts = document.getElementById('timerSpan'); if(ts) ts.innerText = timeLeft; }
        }, 1000);
    }
    function resetTimer() { startTimer(); }
    function finishExam() {
        clearInterval(timerInt);
        examActive = false;
        let score = 0;
        currentExam.forEach((q, idx) => { if(userAns[idx] !== null && userAns[idx] !== -1 && userAns[idx] === q.correct-1) score++; });
        quizDiv.innerHTML = `<div style="text-align:center;"><h2>🏆 نتيجتك: ${score}/${currentExam.length} 🏆</h2><p>${score>=21 ? '🎉 مبروك نجحت! 🎉' : '⚠️ حاول مرة أخرى بعد المراجعة ⚠️'}</p><button id="restartExamBtn">🔄 إعادة الامتحان</button><button id="whatsBtn" style="background:#25D366;">📞 تواصل مع المدرب</button></div>`;
        document.getElementById('restartExamBtn')?.addEventListener('click', () => { startExam(); });
        document.getElementById('whatsBtn')?.addEventListener('click', () => { window.open('https://wa.me/212669048312','_blank'); });
        startBtn.style.display = 'block';
    }
    startBtn.addEventListener('click', startExam);
    initLessons();
</script>
</body>
</html>